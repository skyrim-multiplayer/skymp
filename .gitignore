# ── Source directories ─────────────────────────────────────────────────────────
# Client repo is cloned here by `npm run setup` — not tracked in this repo.
skymp5-backend/sources/client/

# SKSE binaries are large and placed manually — only the README is tracked.
skymp5-backend/sources/skse/*.exe
skymp5-backend/sources/skse/*.dll

# ── Generated output ───────────────────────────────────────────────────────────
# Both files are rebuilt by `npm run merge` — do not track them in git.
skymp5-backend/public/files/*.zip
skymp5-backend/data/files-version.json
skymp5-backend/data/
# Need to exclude backend/data because these files will change with the server running. Make sure they can still be downloaded though.
# public/files/root/ is rebuilt by the merge pipeline.
# Uncomment the line below if you prefer to generate it on the server rather
# than track it in git (requires running `npm run merge` on every deploy).
# public/files/root/

# Large runtime binaries (already in the generated root)
skymp5-backend/public/files/root/Data/Platform/Distribution/RuntimeDependencies/libcef.dll
skymp5-backend/public/files/root/Data/Platform/Distribution/RuntimeDependencies/libnode.dll

