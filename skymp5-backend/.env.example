# ── HTTP server ───────────────────────────────────────────────────────────────
# Port the Express backend listens on.
PORT=4000

# ── WebSocket relay ───────────────────────────────────────────────────────────
# Port for the in-game chat WebSocket relay.
WS_PORT=7778
# Shared secret between the relay and the gamemode.
RELAY_SECRET=replace-with-a-strong-random-secret

# ── Game server connection ────────────────────────────────────────────────────
# IP / hostname of the game server (for status checks and metrics proxy).
SKYMP_HOST=127.0.0.1

# IP for the public, set this to your server's public IP
SERVER_ADDRESS=

# UDP port of the game server.
SKYMP_PORT=7777

# ── Server metadata ───────────────────────────────────────────────────────────
# These values are returned by GET /api/serverinfo and GET /api/servers.
# Keep them in sync with the game server's own server-settings.json.
SERVER_NAME=Frostfall Roleplay
SERVER_MAX_PLAYERS=100
# Set to false to use online mode (session tokens via this backend).
# Must match offlineMode in the game server's server-settings.json.
SERVER_OFFLINE_MODE=false
SERVER_NPC_ENABLED=false
# Optional short label shown in the launcher (e.g. "Roleplay", "PvP").
# SERVER_GAMEMODE=Roleplay

# ── Master API (online mode) ──────────────────────────────────────────────────
# This backend acts as the master API for session validation.
# SERVER_MASTER_KEY is an arbitrary shared secret — it must match
# masterKey in the game server's server-settings.json.
# MASTER_URL is the public URL of this backend — it must match
# master in the game server's server-settings.json.
SERVER_MASTER_KEY=replace-with-a-strong-random-secret
MASTER_URL=https://api.example.com
# Shared secret between the backend and the game server for purchase authorization.
# Must match masterApiAuthToken in the game server's server-settings.json.
MASTER_API_AUTH_TOKEN=replace-with-a-strong-random-secret

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Redirect URI registered in the Discord application (must match exactly).
# DISCORD_REDIRECT_URI=https://your-backend.example.com/api/users/login-discord/callback

DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=server_token_here

# ── Admin dashboard (Discord OAuth) ──────────────────────────────────────────
# Standalone dashboard server. Point a subdomain at this port/service.
DASHBOARD_PORT=4002
DASHBOARD_PUBLIC_URL=https://dashboard.example.com
# Public API base used by the dashboard browser app.
DASHBOARD_API_BASE_URL=https://api.example.com
# Separate redirect URI for the admin dashboard OAuth flow.
# Must be added to the Discord app's OAuth2 redirect list.
# DISCORD_DASHBOARD_REDIRECT_URI=https://your-backend.example.com/auth/dashboard/callback
# Comma-separated list of Discord user IDs allowed to access the admin dashboard.
DASHBOARD_DISCORD_IDS=
# Public URL of the website — used to redirect back after dashboard OAuth.
WEBSITE_URL=https://your-website.example.com
# URL of the local Frostfall-Admin service (never expose to the internet).
ADMIN_URL=http://localhost:5001
# Shared secret between the backend and the admin service (must match ADMIN_TOKEN in Frostfall-Admin/.env).
ADMIN_TOKEN=

# ── Metrics HTTP auth ─────────────────────────────────────────────────────────
# Basic auth credentials for the game server's /metrics endpoint (port 3000).
# Must match the metricsAuth block in the game server's server-settings.json.
# Leave empty if the metrics endpoint has no auth configured.
METRICS_USER=
METRICS_PASSWORD=

# ── Server lockdown ───────────────────────────────────────────────────────────
# When SERVER_LOCKED=true, only Discord users with one of SERVER_LOCKED_ROLE_IDS
# or whose IDs appear in SERVER_LOCKED_ALLOW can connect.
# SERVER_LOCKED_ROLE_IDS is comma-separated and can contain multiple role IDs.
# SERVER_LOCKED_ALLOW is a legacy comma-separated list of Discord user IDs.
SERVER_LOCKED=false
SERVER_LOCKED_ROLE_IDS=
SERVER_LOCKED_ALLOW=

# ── Whitelist (active when SERVER_LOCKED=false) ───────────────────────────────
# Managed via data/whitelist.json — edit the JSON array of Discord snowflake IDs.
# When the array is non-empty, only listed users can join.
# When the array is empty, anyone with a valid Discord session can join.
# Example contents: ["123456789012345678", "987654321098765432"]
# Set WHITELIST_ROLE_ID to use a Discord role as the gameplay whitelist instead.
# When set, this role replaces data/whitelist.json as the source of truth.
WHITELIST_ROLE_ID=
BANNED_ROLE_ID=

# ── GitHub webhook ────────────────────────────────────────────────────────────
# Must match the "Secret" field in the GitHub repo webhook settings.
GITHUB_WEBHOOK_SECRET=replace-with-a-strong-random-secret

# Branch that triggers a client pull + merge when a push is received.
# CLIENT_BRANCH=refs/heads/main
