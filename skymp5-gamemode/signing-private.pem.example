# Ed25519 private key used to sign gamemode.js after each build.
# The client verifies the signature via ServerJsVerificationService.
#
# To generate a real key pair:
#   openssl genpkey -algorithm ed25519 -out signing-private.pem
#   openssl pkey -in signing-private.pem -pubout -out signing-public.pem
#
# Copy this file to signing-private.pem and replace the key with your own.
# signing-private.pem is excluded from version control (.gitignore).
-----BEGIN PRIVATE KEY-----
MC4CAQAwBQYDK2VdBCIEIAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
-----END PRIVATE KEY-----
