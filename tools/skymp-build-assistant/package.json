{
  "name": "skymp-build-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Local build supervisor for SkyMP: manifest-driven sync, status, doctor, and dashboard",
  "license": "GPL-3.0",
  "type": "module",
  "bin": {
    "skymp-dev": "./bin/skymp-dev.js"
  },
  "scripts": {
    "build": "npm run build:ui",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "dashboard": "node bin/skymp-dev.js dashboard",
    "dashboard:dev": "node bin/skymp-dev.js dashboard --dev",
    "dashboard-stop": "node bin/skymp-dev.js dashboard-stop"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "express": "^4.21.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "yaml": "^2.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.10"
  }
}
