{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/shared/**/*.ts",
    "src/patches/**/*.ts",
    "src/server/**/*.ts",
    "core/**/*.ts",
    "types.ts"
  ]
}
